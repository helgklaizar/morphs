[Unit]
Description=PocketBase Server (Borsch Shop)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/borsch-shop/backend
# Предполагается, что бинарь pocketbase лежит в /var/www/borsch-shop/backend
ExecStart=/var/www/borsch-shop/backend/pocketbase serve --http=127.0.0.1:8090
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
